# ==============================
# Environment Variables
# Copy this file to .env and fill in your values
# ==============================

# JWT Secret Key (change this to any random string)
JWT_SECRET=SimpleEnergyTVSecret2025

# Server Port
PORT=5000

# ==============================
# GOOGLE SHEETS CONFIGURATION
# ==============================

# Your Google Sheet ID
# Find it in your sheet URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# The name of your sheet tab (exactly as it appears in Google Sheets)
GOOGLE_SHEET_NAME=SUMMARY 2025 onwards

# Path to your Google Service Account credentials JSON file
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# How often to sync with Google Sheets (in milliseconds)
# 60000 = every 60 seconds
SYNC_INTERVAL_MS=60000
