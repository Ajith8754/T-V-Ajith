# ==============================================================
# .gitignore — T&V Simple Energy Portal
# ==============================================================

# -----------------------------------------------
# Environment & Secrets
# -----------------------------------------------
.env
.env.local
.env.*.local
backend/.env
backend/.env.local

# Google Service Account Credentials (NEVER commit this!)
google-credentials.json
backend/google-credentials.json
**/google-credentials.json

# -----------------------------------------------
# Node.js / npm
# -----------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------
# SQLite Database (local runtime data)
# -----------------------------------------------
*.db
*.sqlite
*.sqlite3
backend/*.db

# -----------------------------------------------
# Uploaded Files (runtime uploads directory)
# -----------------------------------------------
backend/uploads/

# -----------------------------------------------
# Frontend Build Output
# -----------------------------------------------
frontend/dist/
frontend/build/
frontend/.vite/

# -----------------------------------------------
# OS & Editor Files
# -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# -----------------------------------------------
# Logs
# -----------------------------------------------
logs/
*.log
